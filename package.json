{
  "name": "@constcrypt/simple-cache",
  "version": "1.0.0",
  "description": "SimpleCache is a small in-memory cache for roblox-ts",
  "main": "out/init.luau",
  "typings": "index.d.ts",
  "scripts": {
    "build": "rbxtsc",
    "watch": "rbxtsc -w",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/constcrypt/SimpleCache.git"
  },
  "keywords": [
    "cache",
    "memory"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/constcrypt/SimpleCache/issues"
  },
  "homepage": "https://github.com/constcrypt/SimpleCache#readme",
  "files": [
    "out",
    "index.d.ts",
    "README.md",
    "LICENSE.md",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/types": "^1.0.915",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-roblox-ts": "^1.4.0",
    "prettier": "^3.8.2",
    "roblox-ts": "^3.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@rbxts/services": "^1.6.0"
  }
}
